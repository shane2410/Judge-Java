#!/bin/sh
# Maven wrapper
MAVEN_VERSION="3.9.9"
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-$MAVEN_VERSION"
if [ ! -d "$MAVEN_HOME" ]; then
  mkdir -p "$MAVEN_HOME"
  MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.tar.gz"
  echo "Downloading Maven $MAVEN_VERSION..."
  if command -v wget > /dev/null 2>&1; then
    wget -q -O /tmp/maven-dist.tar.gz "$MAVEN_URL"
  else
    curl -sL -o /tmp/maven-dist.tar.gz "$MAVEN_URL"
  fi
  tar xzf /tmp/maven-dist.tar.gz -C "$MAVEN_HOME" --strip-components=1
  rm /tmp/maven-dist.tar.gz
fi
exec "$MAVEN_HOME/bin/mvn" "$@"
